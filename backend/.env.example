# =============================================================================
# Where to set these values
# -----------------------------------------------------------------------------
# Local dev: copy this file to `.env` in this folder (`backend/.env`).
#
# Render — Web Service (Node API): Dashboard → your API service → Environment
#   Required: DATABASE_URL, JWT_SECRET, NODE_ENV=production
#   Strongly recommended: APP_BASE_URL = your static site URL (invite / password-reset links).
#     If omitted on Render, the app tries to infer `https://<api-name>-web.onrender.com` from
#     RENDER_EXTERNAL_URL (set automatically on Render).
#   Email (invites, IT, completions): SMTP_HOST, SMTP_USER, SMTP_PASS, EMAIL_FROM (+ SMTP_PORT)
#   Uploads (optional): DO_SPACES_* or R2_* — see below
#
# Render — Static Site (Vite frontend): set build env in THAT service — see `frontend/.env.example`
#   (mainly VITE_API_URL = your API URL, no trailing slash).
#
# Render — Static Site → Redirects/Rewrites: Source `/*` → Destination `/index.html` → Action Rewrite
#   (so /login and other client routes load the SPA).
# =============================================================================

PORT=5000
JWT_SECRET=replace_with_secure_secret
DB_PATH=./lms.sqlite

# Public URL of the React app (invite + password-reset links). Required in production (e.g. Render static site).
# Example: https://your-app.onrender.com  — NOT the API URL unless you serve the SPA from the same host.
# On Render, if unset, the API may infer the static site as *-web.onrender.com from RENDER_EXTERNAL_URL (API host).
# APP_BASE_URL=https://your-frontend.onrender.com
# FRONTEND_URL=  (alias for APP_BASE_URL)

# Password reset link lifetime (minutes). Default 60.
# PASSWORD_RESET_MINUTES=60

# --- Database: omit DATABASE_URL to use SQLite (DB_PATH). Set DATABASE_URL for PostgreSQL (e.g. DigitalOcean managed DB).
# DATABASE_URL=postgresql://user:pass@host:25060/defaultdb?sslmode=require
# Managed Postgres often requires TLS. To use a local Postgres without SSL: DATABASE_SSL=false
# DATABASE_SSL=false

# First boot only: create admin@company.com if no Admin exists. Set to 0 after your real admin is ready.
# SEED_DEFAULT_ADMIN=1
UPLOAD_DIR=./uploads
# Max lesson video upload size (MB). Default 500.
# UPLOAD_MAX_MB=500

# If uploads fail with "access key does not exist" but you use DigitalOcean Spaces, you may have R2_* set in the OS env.
# Add STORAGE_SKIP_R2=1 to force Spaces, or clear R2_* variables. Uploads prefer Spaces over R2 when both are set.
# STORAGE_SKIP_R2=1

# --- Cloudflare R2 (optional). Set all five to store lesson videos in R2; omit any one to keep local disk.
# R2_ACCOUNT_ID=
# R2_BUCKET_NAME=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# --- DigitalOcean Spaces (optional). If set (and R2 is NOT fully set), lesson videos go to Spaces.
# Create: Spaces Object Storage → Create Space → API → Spaces Keys. Region e.g. nyc3, tor1.
# DO_SPACES_PUBLIC_URL = file CDN or origin base, no trailing slash, e.g.
#   https://your-space.tor1.cdn.digitaloceanspaces.com  or  https://your-space.tor1.digitaloceanspaces.com
# DO_SPACES_BUCKET=
# DO_SPACES_REGION=tor1
# Optional: paste exact API endpoint from Connection details (otherwise built from region).
# DO_SPACES_ENDPOINT=https://tor1.digitaloceanspaces.com
# DO_SPACES_KEY=
# DO_SPACES_SECRET=
# DO_SPACES_PUBLIC_URL=
# If uploads fail with "access key ID ... does not exist", the key was revoked or mistyped — create a new Spaces key.
# For local-only dev, leave DO_SPACES_KEY empty so videos stay in UPLOAD_DIR.
# If you update .env but uploads still use old keys, remove DO_SPACES_* from your OS/shell environment — the server loads .env with override so file values win.

# --- Outlook / Microsoft 365 email ---
# Course completion: managers receive mail at their `users.email`.
# IT tickets: every user with department = IT receives mail when someone submits a ticket.
# In Microsoft 365: enable SMTP AUTH for the mailbox you use as SMTP_USER, or use an app password if required.
# Typical Exchange Online:
#   SMTP_HOST=smtp.office365.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=noreply@yourcompany.com
#   SMTP_PASS=your_password_or_app_password
#   EMAIL_FROM="AGC University <noreply@yourcompany.com>"
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
# Optional: SMTP_REQUIRE_TLS=true (some Microsoft 365 tenants)
# Optional: SMTP_TLS_REJECT_UNAUTHORIZED=false (dev only; weakens TLS verification)
# Optional: SMTP_DEBUG=1 (verbose SMTP logs)
# Test: npm run test:smtp -- you@example.com

# --- Gmail example (use App Password, not your normal password) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# EMAIL_FROM="AGC University <you@gmail.com>"
